PORT=8000
NODE_ENV=development
MONGODB_URI=mongodb://127.0.0.1:27017/ikhnayd

# Comma-separated browser origins (no trailing slashes)
CORS_ORIGIN=http://localhost:3000,http://localhost:3001,http://localhost:3002

# JWT secret for admin tokens — change in production!
ADMIN_JWT_SECRET=change-me-in-production

# Legacy env-based super admin (fallback if no DB user exists)
ADMIN_USERNAME=superadmin
ADMIN_PASSWORD=admin1234
