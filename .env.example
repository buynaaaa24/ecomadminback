PORT=8000
NODE_ENV=development
MONGODB_URI=mongodb://127.0.0.1:27017/ikhnayd

# Comma-separated browser origins (no trailing slashes)
CORS_ORIGIN=http://localhost:7000,http://localhost:7001,http://localhost:7002,http://103.236.194.106:7000,http://103.236.194.106:7001,http://103.236.194.106:7002

# JWT secret for admin tokens — change in production!
ADMIN_JWT_SECRET=change-me-in-production

# Legacy env-based super admin (fallback if no DB user exists)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Public server host used to build QPay callback URLs
SERVER_HOST=103.236.194.106

# QPay payment gateway (same packages as posBackv2 / udirdlagaBack)
# quickqpaypack  -> uses QPAY_MERCHANT_SERVER
# quickqpaypackv2 -> uses QPAY_SERVER (prod) / QPAY_TEST_SERVER (sandbox)
QPAY_MERCHANT_SERVER=https://quickqr.qpay.mn/
QPAY_SERVER=https://merchant.qpay.mn/
QPAY_TEST_SERVER=https://merchant-sandbox.qpay.mn/
# Global fallback credentials — per-tenant username/password stored in DB takes precedence
QPAY_USERNAME=
QPAY_PASSWORD=
